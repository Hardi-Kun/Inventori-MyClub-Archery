<%- include('../../v_layout/head') %>

<div class="container" style="margin-top: 80px;">
    <div class="row justify-content-center">
        <div class="col-md-8">

            <!-- BREADCRUMB -->
            <nav aria-label="breadcrumb" class="mb-3">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item">
                        <a href="/perawatan" class="text-decoration-none">Perawatan</a>
                    </li>
                    <li class="breadcrumb-item active">Catat Perbaikan</li>
                </ol>
            </nav>

            <div class="card shadow-sm border-0">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0">
                        <i class="fa-solid fa-screwdriver-wrench me-2"></i> Catat Perbaikan Alat
                    </h5>
                </div>
                <div class="card-body">
                    <form action="/perawatan/tambah" method="POST">

                        <div class="mb-3">
                            <label class="form-label">Pilih Alat <span class="text-danger">*</span></label>
                            <select name="form_kode_alat" class="form-select" required
                                onchange="isiNamaAlat(this)">
                                <option value="">-- Pilih Alat --</option>
                                <% for(let i in alat) { %>
                                    <option value="<%= alat[i].kode %>"
                                        data-nama="<%= alat[i].nama %>">
                                        [<%= alat[i].kode %>] <%= alat[i].nama %>
                                    </option>
                                <% } %>
                            </select>
                        </div>

                        <input type="hidden" name="form_nama_alat" id="form_nama_alat">

                        <div class="mb-3">
                            <label class="form-label">Masalah / Kerusakan <span class="text-danger">*</span></label>
                            <textarea name="form_masalah" class="form-control" rows="3"
                                placeholder="Deskripsikan masalah atau kerusakan alat" required></textarea>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Tanggal Lapor <span class="text-danger">*</span></label>
                                <input type="date" name="form_tgl_lapor" class="form-control"
                                    value="<%= moment().format('YYYY-MM-DD') %>" required>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Status Perbaikan <span class="text-danger">*</span></label>
                                <select name="form_status_perbaikan" class="form-select" required>
                                    <option value="Menunggu">Menunggu</option>
                                    <option value="Dalam Perbaikan">Dalam Perbaikan</option>
                                    <option value="Selesai">Selesai</option>
                                </select>
                            </div>
                        </div>

                        <div class="d-flex gap-2 justify-content-end">
                            <a href="/perawatan" class="btn btn-secondary">
                                <i class="fa-solid fa-arrow-left me-1"></i> Batal
                            </a>
                            <button type="submit" class="btn btn-success">
                                <i class="fa-solid fa-floppy-disk me-1"></i> Simpan
                            </button>
                        </div>

                    </form>
                </div>
            </div>

        </div>
    </div>
</div>

<script>
    function isiNamaAlat(select) {
        const option = select.options[select.selectedIndex]
        document.getElementById('form_nama_alat').value = option.getAttribute('data-nama') || ''
    }
</script>

</body>
</html>