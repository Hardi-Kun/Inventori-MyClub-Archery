<%- include('../../v_layout/head') %>

<div class="container" style="margin-top: 80px;">
    <div class="row justify-content-center">
        <div class="col-md-8">

            <!-- BREADCRUMB -->
            <nav aria-label="breadcrumb" class="mb-3">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item">
                        <a href="/pinjaman" class="text-decoration-none">Peminjaman</a>
                    </li>
                    <li class="breadcrumb-item active">Catat Peminjaman</li>
                </ol>
            </nav>

            <div class="card shadow-sm border-0">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0">
                        <i class="fa-solid fa-plus me-2"></i> Catat Peminjaman Alat
                    </h5>
                </div>
                <div class="card-body">
                    <form action="/pinjaman/tambah" method="POST">

                        <div class="mb-3">
                            <label class="form-label">Pilih Alat <span class="text-danger">*</span></label>
                            <select name="form_kode_alat" class="form-select" required
                                onchange="isiNamaAlat(this)">
                                <option value="">-- Pilih Alat Tersedia --</option>
                                <% for(let i in alat) { %>
                                    <option value="<%= alat[i].kode %>" 
                                        data-nama="<%= alat[i].nama %>">
                                        [<%= alat[i].kode %>] <%= alat[i].nama %>
                                    </option>
                                <% } %>
                            </select>
                        </div>

                        <input type="hidden" name="form_nama_alat" id="form_nama_alat">

                        <div class="mb-3">
                            <label class="form-label">Nama Peminjam <span class="text-danger">*</span></label>
                            <input type="text" name="form_peminjam" class="form-control"
                                placeholder="Nama anggota / atlet" required>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Tanggal Pinjam <span class="text-danger">*</span></label>
                                <input type="date" name="form_tgl_pinjam" class="form-control"
                                    value="<%= moment().format('YYYY-MM-DD') %>" required>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Rencana Kembali</label>
                                <input type="date" name="form_tgl_rencana_kembali" class="form-control">
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Keterangan</label>
                            <input type="text" name="form_keterangan" class="form-control"
                                placeholder="Untuk latihan, lomba, dsb.">
                        </div>

                        <div class="d-flex gap-2 justify-content-end">
                            <a href="/pinjaman" class="btn btn-secondary">
                                <i class="fa-solid fa-arrow-left me-1"></i> Batal
                            </a>
                            <button type="submit" class="btn btn-success">
                                <i class="fa-solid fa-floppy-disk me-1"></i> Simpan
                            </button>
                        </div>

                    </form>
                </div>
            </div>

        </div>
    </div>
</div>

<script>
    function isiNamaAlat(select) {
        const option = select.options[select.selectedIndex]
        document.getElementById('form_nama_alat').value = option.getAttribute('data-nama') || ''
    }
</script>

</body>
</html>