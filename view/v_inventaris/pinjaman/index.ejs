<%- include('../../v_layout/head') %>

<div class="container" style="margin-top: 80px;">

    <!-- HEADER -->
    <div class="row mb-3">
        <div class="col-md-8">
            <h4 class="mb-0">
                <i class="fa-solid fa-hand-holding me-2"></i> Peminjaman Alat
            </h4>
            <% if (terlambat.length > 0) { %>
                <div class="alert alert-danger mt-2 py-2">
                    <i class="fa-solid fa-triangle-exclamation me-1"></i>
                    <strong><%= terlambat.length %> alat</strong> terlambat dikembalikan!
                </div>
            <% } %>
        </div>
        <div class="col-md-4 text-end">
            <a href="/pinjaman/tambah" class="btn btn-success">
                <i class="fa-solid fa-plus me-1"></i> Catat Peminjaman
            </a>
        </div>
    </div>

    <!-- TABEL PEMINJAMAN -->
    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>No</th>
                            <th>Kode Alat</th>
                            <th>Nama Alat</th>
                            <th>Peminjam</th>
                            <th>Tgl Pinjam</th>
                            <th>Rencana Kembali</th>
                            <th>Tgl Kembali</th>
                            <th>Keterangan</th>
                            <th>Status</th>
                            <th>Aksi</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (pinjaman.length == 0) { %>
                            <tr>
                                <td colspan="10" class="text-center text-muted py-4">
                                    Belum ada data peminjaman
                                </td>
                            </tr>
                        <% } %>
                        <% for(let i in pinjaman) { %>
                        <tr>
                            <td><%= parseInt(i) + 1 %></td>
                            <td><code><%= pinjaman[i].kode_alat %></code></td>
                            <td class="fw-500"><%= pinjaman[i].nama_alat %></td>
                            <td><%= pinjaman[i].peminjam %></td>
                            <td><%= moment(pinjaman[i].tgl_pinjam).format('DD-MM-YYYY') %></td>
                            <td>
                                <% if (pinjaman[i].status == 'Dipinjam' && pinjaman[i].tgl_rencana_kembali < new Date()) { %>
                                    <span class="text-danger fw-bold">
                                        <%= moment(pinjaman[i].tgl_rencana_kembali).format('DD-MM-YYYY') %>
                                        <i class="fa-solid fa-triangle-exclamation ms-1"></i>
                                    </span>
                                <% } else { %>
                                    <%= pinjaman[i].tgl_rencana_kembali ? moment(pinjaman[i].tgl_rencana_kembali).format('DD-MM-YYYY') : '-' %>
                                <% } %>
                            </td>
                            <td><%= pinjaman[i].tgl_kembali ? moment(pinjaman[i].tgl_kembali).format('DD-MM-YYYY') : '-' %></td>
                            <td><small class="text-muted"><%= pinjaman[i].keterangan || '-' %></small></td>
                            <td>
                                <% if (pinjaman[i].status == 'Dipinjam') { %>
                                    <span class="badge bg-warning text-dark">Dipinjam</span>
                                <% } else { %>
                                    <span class="badge bg-success">Kembali</span>
                                <% } %>
                            </td>
                            <td>
                                <div class="d-flex gap-1">
                                    <% if (pinjaman[i].status == 'Dipinjam') { %>
                                        <form action="/pinjaman/kembalikan/<%= pinjaman[i].id %>" method="POST">
                                            <input type="hidden" name="kode_alat" value="<%= pinjaman[i].kode_alat %>">
                                            <button type="submit" class="btn btn-sm btn-success"
                                                onclick="return confirm('Konfirmasi alat sudah dikembalikan?')">
                                                <i class="fa-solid fa-rotate-left"></i>
                                            </button>
                                        </form>
                                    <% } %>
                                    <a href="/pinjaman/hapus/<%= pinjaman[i].id %>"
                                        class="btn btn-sm btn-danger"
                                        onclick="return confirm('Yakin hapus data ini?')">
                                        <i class="fa-solid fa-trash"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

</div>

</body>
</html>